# 로컬 개발용 환경변수 예시.
#   cp .env.example .env  후 필요한 값만 채우면 됩니다.
#   (docker-compose가 이 값들을 각 서비스로 주입)

# ── PostgreSQL ──────────────────────────────
POSTGRES_DB=settlement
POSTGRES_USER=settlement
POSTGRES_PASSWORD=settlement

# ── Django (core) ───────────────────────────
DJANGO_SECRET_KEY=dev-insecure-secret-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# ── FastAPI (ai) ────────────────────────────
# OpenAI(LLM·비전)는 실제 Agent 동작 시에만 필요. 스캐폴드 부팅에는 비어 있어도 됨.
OPENAI_API_KEY=

# ── Web (vite) ──────────────────────────────
# 기본값 /api → Nginx(8080) 또는 vite proxy(5173) 경유로 Django에 도달.
VITE_API_BASE_URL=/api
